# Store binary app-icon artifacts in Git LFS. Patterns are relative to this
# directory and apply recursively (root icons/, android/, ios/, src/...).
# icon.json (Icon Composer source manifest) stays a normal text blob so it
# remains diffable.
#
# Sources of truth live in src/ (autosk.icon + autosk.png); everything else
# here is generated by scripts/update-gui-icons.sh.
*.png  filter=lfs diff=lfs merge=lfs -text
*.icns filter=lfs diff=lfs merge=lfs -text
*.ico  filter=lfs diff=lfs merge=lfs -text
*.car  filter=lfs diff=lfs merge=lfs -text
