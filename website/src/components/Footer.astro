---
import {
  GITHUB_URL,
  DOCS_URL,
  RELEASES_URL,
  CHANGELOG_URL,
  LICENSE_URL,
} from "../data/nav.ts";

const columns: { title: string; links: { label: string; href: string }[] }[] = [
  {
    title: "Product",
    links: [
      { label: "Features", href: "#features" },
      { label: "How it works", href: "#how-it-works" },
      { label: "Install", href: "#install" },
    ],
  },
  {
    title: "Docs",
    links: [
      { label: "Concepts", href: `${DOCS_URL}/concepts.md` },
      { label: "Workflows", href: `${DOCS_URL}/workflows.md` },
      { label: "Daemon", href: `${DOCS_URL}/daemon.md` },
      { label: "Extensions", href: `${DOCS_URL}/extensions.md` },
      { label: "Lazy", href: `${DOCS_URL}/lazy.md` },
    ],
  },
  {
    title: "Project",
    links: [
      { label: "GitHub", href: GITHUB_URL },
      { label: "Releases", href: RELEASES_URL },
      { label: "Changelog", href: CHANGELOG_URL },
      { label: "License", href: LICENSE_URL },
    ],
  },
];
---
<footer class="border-t border-border/60 bg-bg-1/40">
  <div class="mx-auto max-w-[1120px] px-5 py-14 sm:px-8">
    <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-4">
      <div>
        <div class="flex items-center gap-2.5">
          <span
            class="grid h-7 w-7 place-items-center rounded-md border border-border bg-bg-2 font-mono text-sm font-bold text-accent"
            >a</span
          >
          <span class="font-mono text-[15px] font-semibold tracking-tight text-fg">autosk</span>
        </div>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-fg-mute">
          A task manager and workflow engine for coding agents. Local, file-based, open.
        </p>
      </div>

      {columns.map((col) => (
        <nav aria-label={col.title}>
          <h3 class="font-mono text-xs uppercase tracking-wider text-fg-mute">{col.title}</h3>
          <ul class="mt-3 space-y-2">
            {col.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="link-underline text-sm text-fg-dim"
                  {...(l.href.startsWith("http")
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                  >{l.label}</a
                >
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <div
      class="mt-12 flex flex-col gap-3 border-t border-border/60 pt-6 text-xs text-fg-mute sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="font-mono">© Earendil · MIT · autosk</p>
      <p class="font-mono">Local-first · No database · Open source</p>
    </div>
  </div>
</footer>
