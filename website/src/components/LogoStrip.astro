---
import Icon from "./ui/Icon.astro";

/** Thin credibility band (plan §6.2): instant trust, no wall of logos. */
const items = [
  { icon: "code", label: "Open source · MIT" },
  { icon: "terminal", label: "macOS · Linux · iOS" },
  { icon: "lock", label: "Signed & notarized cask" },
  { icon: "database", label: "No database — just files" },
];
---
<div class="border-y border-border/60 bg-bg-1/40">
  <div class="mx-auto max-w-[1120px] px-5 py-4 sm:px-8">
    <ul
      class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 font-mono text-xs text-fg-mute"
    >
      {items.map((it) => (
        <li class="flex items-center gap-2">
          <Icon name={it.icon} size={15} class="text-fg-dim" />
          <span>{it.label}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
