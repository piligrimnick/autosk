---
import Icon from "./ui/Icon.astro";
import { navLinks, GITHUB_URL } from "../data/nav.ts";
---
<header
  class="sticky top-0 z-40 border-b border-border/60 bg-bg/80 backdrop-blur-md supports-[backdrop-filter]:bg-bg/65"
>
  <nav class="mx-auto flex h-16 max-w-[1120px] items-center gap-6 px-5 sm:px-8">
    <a href="#top" class="flex items-center gap-2.5" aria-label="autosk home">
      <span
        class="grid h-7 w-7 place-items-center rounded-md border border-border bg-bg-2 font-mono text-sm font-bold text-accent"
        >a</span
      >
      <span class="font-mono text-[15px] font-semibold tracking-tight text-fg">autosk</span>
    </a>

    <ul class="ml-2 hidden items-center gap-6 md:flex">
      {navLinks.map((l) => (
        <li>
          <a
            href={l.href}
            class="link-underline text-sm text-fg-dim"
            {...(l.href.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            >{l.label}</a
          >
        </li>
      ))}
    </ul>

    <div class="ml-auto flex items-center gap-2">
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden h-9 w-9 place-items-center rounded-md border border-border bg-bg-2 text-fg-dim transition-colors hover:border-[#41495a] hover:text-fg sm:grid"
        aria-label="autosk on GitHub"
      >
        <Icon name="github" size={18} />
      </a>
      <a
        href="#install"
        class="inline-flex items-center gap-2 rounded-[var(--radius)] bg-accent px-3.5 py-2 text-sm font-medium text-white transition-colors hover:bg-[#3d7df0]"
      >
        <Icon name="terminal" size={15} />
        Install
      </a>
    </div>
  </nav>
</header>
