---
/**
 * Inline-SVG / diagram wrapper (plan §7): a bordered, dark card that lets a
 * wide diagram scroll horizontally on small screens and centers it on large
 * ones. Animation lives in the slotted SVG and is gated on motion preference.
 */
interface Props {
  label?: string;
  class?: string;
}
const { label, class: cls = "" } = Astro.props;
---
<figure
  class={`reveal overflow-hidden rounded-2xl border border-border bg-bg-1/60 p-4 sm:p-6 ${cls}`}
  role="group"
  aria-label={label}
>
  <div class="overflow-x-auto">
    <div class="min-w-[640px]">
      <slot />
    </div>
  </div>
  {label && <figcaption class="mt-3 text-center font-mono text-xs text-fg-mute">{label}</figcaption>}
</figure>
