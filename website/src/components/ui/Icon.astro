---
/**
 * Inline SVG icon set — hand-authored, license-free line icons on a 24×24 grid,
 * drawn with `currentColor` so they inherit text color. Avoids an icon-library
 * dependency (plan keeps the build zero-extra-deps where practical).
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 24, class: cls = "" } = Astro.props;

// Stroke-style icons (fill:none). Each value is the inner markup of the <svg>.
const stroke: Record<string, string> = {
  code: `<path d="M8 6 3 12l5 6"/><path d="M16 6 21 12l-5 6"/><path d="M13.5 4 10.5 20"/>`,
  handoff: `<path d="M3 8h14"/><path d="M14 5l3 3-3 3"/><path d="M21 16H7"/><path d="M10 13l-3 3 3 3"/>`,
  shield: `<path d="M12 3 20 6v5c0 4.5-3.4 7.9-8 9-4.6-1.1-8-4.5-8-9V6Z"/><path d="m9 11.5 2 2 4-4"/>`,
  lifebuoy: `<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3.6"/><path d="m5.6 5.6 3.7 3.7"/><path d="m14.7 14.7 3.7 3.7"/><path d="m18.4 5.6-3.7 3.7"/><path d="m9.3 14.7-3.7 3.7"/>`,
  boxes: `<rect x="3" y="3" width="7.5" height="7.5" rx="1.2"/><rect x="13.5" y="3" width="7.5" height="7.5" rx="1.2"/><rect x="8.25" y="13.5" width="7.5" height="7.5" rx="1.2"/>`,
  database: `<ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v12c0 1.7 3.6 3 8 3s8-1.3 8-3V6"/><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/>`,
  screens: `<rect x="2" y="4" width="13" height="9" rx="1.4"/><path d="M6 17h7"/><path d="M8.5 13v4"/><rect x="16.5" y="7" width="5.5" height="13" rx="1.4"/>`,
  plug: `<path d="M9 2v5"/><path d="M15 2v5"/><path d="M7 7h10v3a5 5 0 0 1-10 0Z"/><path d="M12 15v7"/>`,
  puzzle: `<path d="M10 4a2 2 0 0 1 4 0c0 1 .8 1.5 1.6 1.2l2.4-.8.8 2.4c.3.8-.2 1.6-1.2 1.6a2 2 0 0 0 0 4c1 0 1.5.8 1.2 1.6l-.8 2.4-2.4-.8c-.8-.3-1.6.2-1.6 1.2a2 2 0 0 1-4 0c0-1-.8-1.5-1.6-1.2l-2.4.8-.8-2.4C4.9 14.2 5.4 13.4 6.4 13.4a2 2 0 0 0 0-4C5.4 9.4 4.9 8.6 5.2 7.8l.8-2.4 2.4.8C9.2 6.5 10 5 10 4Z"/>`,
  terminal: `<rect x="3" y="4.5" width="18" height="15" rx="1.6"/><path d="m7.5 9.5 3 2.5-3 2.5"/><path d="M12.5 15h4"/>`,
  arrow: `<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>`,
  copy: `<rect x="9" y="9" width="11" height="11" rx="1.6"/><path d="M5 15H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h9a1 1 0 0 1 1 1v1"/>`,
  check: `<path d="m4 12 5 5L20 6"/>`,
  branch: `<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="9" r="3"/><path d="M6 9v6"/><path d="M18 12a9 9 0 0 1-9 9"/>`,
  eye: `<path d="M2 12s3.8-7 10-7 10 7 10 7-3.8 7-10 7S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/>`,
  layers: `<path d="M12 3 21 8l-9 5-9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 16 9 5 9-5"/>`,
  lock: `<rect x="4.5" y="10.5" width="15" height="10" rx="1.8"/><path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"/><path d="M12 14.5v2.5"/>`,
  spark: `<path d="M12 3v4"/><path d="M12 17v4"/><path d="M3 12h4"/><path d="M17 12h4"/><path d="m6 6 2.5 2.5"/><path d="m15.5 15.5 2.5 2.5"/><path d="m18 6-2.5 2.5"/><path d="m8.5 15.5-2.5 2.5"/>`,
  loop: `<path d="M21 12a9 9 0 1 1-2.6-6.3"/><path d="M21 4v5h-5"/>`,
};

// Fill-style icons (brand marks).
const fill: Record<string, string> = {
  github: `<path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.57 2.34 1.12 2.91.86.09-.66.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.34 9.34 0 0 1 12 7.07c.85 0 1.71.12 2.51.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.59.69.49A10.04 10.04 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/>`,
};

const isFill = name in fill;
const body = isFill ? fill[name] : (stroke[name] ?? "");
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isFill ? "currentColor" : "none"}
  stroke={isFill ? "none" : "currentColor"}
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-hidden="true"
  set:html={body}
/>
