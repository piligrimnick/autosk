---
import CodeBlock from "./ui/CodeBlock.astro";
import Button from "./ui/Button.astro";
import Icon from "./ui/Icon.astro";
import {
  BREW_INSTALL,
  GITHUB_URL,
  DOCS_URL,
  CHANGELOG_URL,
  LATEST_RELEASE_URL,
  TESTFLIGHT_URL,
} from "../data/nav.ts";

const linuxSnippet = `<span class="tok-comment"># grab the autosk + autoskd binaries (and the GUI</span>
<span class="tok-comment"># .AppImage / .deb) from the latest release.</span>`;
---
<section id="install" class="relative overflow-hidden border-t border-border/60">
  <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(60%_60%_at_50%_0%,rgba(76,141,255,0.12),transparent_70%)]"></div>
  <div class="mx-auto max-w-[820px] px-5 py-24 text-center sm:px-8">
    <p class="eyebrow">install</p>
    <h2 class="mt-4 text-balance text-3xl font-semibold tracking-tight text-fg sm:text-4xl md:text-5xl">
      Run your agents in a loop.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-fg-dim">
      One command installs the CLI, the TUI, and the daemon. Then point it at any repo and go.
    </p>

    <div class="installer mt-10 text-left">
      <input type="radio" name="itab" id="itab-mac" checked />
      <input type="radio" name="itab" id="itab-linux" />
      <input type="radio" name="itab" id="itab-ios" />
      <input type="radio" name="itab" id="itab-src" />

      <div class="tabbar">
        <label for="itab-mac">macOS</label>
        <label for="itab-linux">Linux</label>
        <label for="itab-ios">iOS</label>
        <label for="itab-src">From source</label>
      </div>

      <div class="panels mt-4">
        <div id="p-mac">
          <CodeBlock
            title="Homebrew cask"
            code={`<span class="tok-accent">$</span> ${BREW_INSTALL}`}
            copyText={BREW_INSTALL}
          />
          <p class="mt-2 font-mono text-xs text-fg-mute">Signed + notarized. Bundles the CLI/TUI and the daemon.</p>
        </div>

        <div id="p-linux">
          <CodeBlock title="GitHub Release" code={linuxSnippet} />
          <div class="mt-3">
            <Button href={LATEST_RELEASE_URL} variant="ghost" external>
              <Icon name="arrow" size={15} />
              Latest GitHub Release
            </Button>
          </div>
        </div>

        <div id="p-ios">
          <CodeBlock title="Apple TestFlight" code={`<span class="tok-comment"># install the autosk iOS app (beta) from</span>
<span class="tok-comment"># Apple TestFlight — no App Store listing yet.</span>`} />
          <div class="mt-3">
            <Button href={TESTFLIGHT_URL} variant="ghost" external>
              <Icon name="arrow" size={15} />
              iOS App (beta)
            </Button>
          </div>
          <p class="mt-2 font-mono text-xs text-fg-mute">Requires the TestFlight app. Companion to the daemon — watch and steer sessions on the go.</p>
        </div>

        <div id="p-src">
          <CodeBlock
            title="From source"
            code={`<span class="tok-accent">$</span> make install`}
            copyText="make install"
          />
          <p class="mt-2 font-mono text-xs text-fg-mute">Any platform. Builds and installs both binaries.</p>
        </div>
      </div>
    </div>

    <div class="mt-6">
      <CodeBlock
        bare
        code={`<span class="tok-accent">$</span> autosk lazy`}
        copyText="autosk lazy"
        class="mx-auto max-w-xs"
      />
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 font-mono text-sm text-fg-dim">
      <a href={DOCS_URL} target="_blank" rel="noopener noreferrer" class="link-underline">Docs</a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="link-underline">GitHub</a>
      <a href={CHANGELOG_URL} target="_blank" rel="noopener noreferrer" class="link-underline">Changelog</a>
    </div>
  </div>
</section>

<style>
  /* CSS-only tabs: radios precede .tabbar and .panels as siblings, so the
     general-sibling combinator can drive both the active label and the visible
     panel with zero JavaScript. */
  .installer > input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .tabbar {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    border: 1px solid var(--border);
    background: var(--bg-1);
    border-radius: 10px;
  }
  .tabbar label {
    cursor: pointer;
    border-radius: 7px;
    padding: 6px 14px;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg-dim);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tabbar label:hover {
    color: var(--fg);
  }
  .panels > div {
    display: none;
  }
  #itab-mac:checked ~ .tabbar label[for="itab-mac"],
  #itab-linux:checked ~ .tabbar label[for="itab-linux"],
  #itab-ios:checked ~ .tabbar label[for="itab-ios"],
  #itab-src:checked ~ .tabbar label[for="itab-src"] {
    background: var(--accent);
    color: #fff;
  }
  #itab-mac:checked ~ .panels #p-mac,
  #itab-linux:checked ~ .panels #p-linux,
  #itab-ios:checked ~ .panels #p-ios,
  #itab-src:checked ~ .panels #p-src {
    display: block;
  }
  /* Keyboard focus visibility for the hidden radios. */
  .installer > input[type="radio"]:focus-visible ~ .tabbar label[for] {
    outline: none;
  }
  #itab-mac:focus-visible ~ .tabbar label[for="itab-mac"],
  #itab-linux:focus-visible ~ .tabbar label[for="itab-linux"],
  #itab-ios:focus-visible ~ .tabbar label[for="itab-ios"],
  #itab-src:focus-visible ~ .tabbar label[for="itab-src"] {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
